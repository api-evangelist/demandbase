{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CreateCampaignRequest",
  "title": "CreateCampaignRequest",
  "type": "object",
  "required": [
    "name",
    "budget",
    "start_date"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Campaign name"
    },
    "budget": {
      "type": "number",
      "description": "Campaign budget in USD"
    },
    "daily_budget": {
      "type": "number",
      "description": "Daily budget cap in USD"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Campaign start date"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "Campaign end date"
    },
    "audience_id": {
      "type": "string",
      "description": "Target audience segment ID"
    }
  }
}