{
  "opencollection": "1.0.0",
  "info": {
    "name": "Demandbase Data Export API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Export Jobs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List export jobs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/export/v1/jobs",
            "params": [
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by job status"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve a list of data export jobs with their current status and metadata."
        },
        {
          "info": {
            "name": "Demandbase Create an export job",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/export/v1/jobs",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new asynchronous data export job. Specify the entity type, fields to export, filters, and date range. Exported data is delivered as downloadable CSV files."
        },
        {
          "info": {
            "name": "Demandbase Get export job status",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/export/v1/jobs/:jobId",
            "params": [
              {
                "name": "jobId",
                "value": "",
                "type": "path",
                "description": "Export job unique identifier"
              }
            ]
          },
          "docs": "Retrieve the current status and details of a specific export job, including progress information and download URLs when complete."
        },
        {
          "info": {
            "name": "Demandbase Cancel an export job",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/export/v1/jobs/:jobId",
            "params": [
              {
                "name": "jobId",
                "value": "",
                "type": "path",
                "description": "Export job unique identifier"
              }
            ]
          },
          "docs": "Cancel a pending or processing export job."
        },
        {
          "info": {
            "name": "Demandbase List exportable entities",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/export/v1/entities"
          },
          "docs": "Retrieve the list of entity types available for export and their supported fields."
        }
      ]
    },
    {
      "info": {
        "name": "Downloads",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase Download export file",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/export/v1/jobs/:jobId/download",
            "params": [
              {
                "name": "jobId",
                "value": "",
                "type": "path",
                "description": "Export job unique identifier"
              },
              {
                "name": "part",
                "value": "",
                "type": "query",
                "description": "Part number for multi-part exports (starts at 1)"
              }
            ]
          },
          "docs": "Download the exported CSV file for a completed export job. Returns a redirect to a pre-signed download URL."
        }
      ]
    }
  ],
  "bundled": true
}