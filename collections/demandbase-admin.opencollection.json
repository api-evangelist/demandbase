{
  "opencollection": "1.0.0",
  "info": {
    "name": "Demandbase Admin API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Users",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List users",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/admin/v1/users",
            "params": [
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by user status"
              },
              {
                "name": "role",
                "value": "",
                "type": "query",
                "description": "Filter by user role"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve a list of all users in the Demandbase One organization with their roles and status."
        },
        {
          "info": {
            "name": "Demandbase Create a user",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/admin/v1/users",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new user in the Demandbase One organization."
        },
        {
          "info": {
            "name": "Demandbase Get a user",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/admin/v1/users/:userId",
            "params": [
              {
                "name": "userId",
                "value": "",
                "type": "path",
                "description": "User unique identifier"
              }
            ]
          },
          "docs": "Retrieve details of a specific user."
        },
        {
          "info": {
            "name": "Demandbase Update a user",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.demandbase.com/admin/v1/users/:userId",
            "params": [
              {
                "name": "userId",
                "value": "",
                "type": "path",
                "description": "User unique identifier"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update an existing user's details and role assignments."
        },
        {
          "info": {
            "name": "Demandbase Delete a user",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/admin/v1/users/:userId",
            "params": [
              {
                "name": "userId",
                "value": "",
                "type": "path",
                "description": "User unique identifier"
              }
            ]
          },
          "docs": "Delete a user from the Demandbase One organization."
        }
      ]
    },
    {
      "info": {
        "name": "API Keys",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List API key sets",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/admin/v1/api-keys"
          },
          "docs": "Retrieve all API key sets for the organization."
        },
        {
          "info": {
            "name": "Demandbase Create an API key set",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/admin/v1/api-keys",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Generate a new API key set for programmatic access to Demandbase APIs."
        },
        {
          "info": {
            "name": "Demandbase Get an API key set",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/admin/v1/api-keys/:keyId",
            "params": [
              {
                "name": "keyId",
                "value": "",
                "type": "path",
                "description": "API key set unique identifier"
              }
            ]
          },
          "docs": "Retrieve details of a specific API key set."
        },
        {
          "info": {
            "name": "Demandbase Delete an API key set",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/admin/v1/api-keys/:keyId",
            "params": [
              {
                "name": "keyId",
                "value": "",
                "type": "path",
                "description": "API key set unique identifier"
              }
            ]
          },
          "docs": "Revoke and delete an API key set."
        }
      ]
    },
    {
      "info": {
        "name": "Roles",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List roles",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/admin/v1/roles"
          },
          "docs": "Retrieve all available roles and their permissions."
        }
      ]
    }
  ],
  "bundled": true
}