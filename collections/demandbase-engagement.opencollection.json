{
  "opencollection": "1.0.0",
  "info": {
    "name": "Demandbase Engagement API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Engagement",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase Get account engagement",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/engagement/accounts/:accountId/engagement",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path",
                "description": "Demandbase account unique identifier"
              },
              {
                "name": "start_date",
                "value": "",
                "type": "query",
                "description": "Start date for engagement data (YYYY-MM-DD)"
              },
              {
                "name": "end_date",
                "value": "",
                "type": "query",
                "description": "End date for engagement data (YYYY-MM-DD)"
              }
            ]
          },
          "docs": "Retrieve the engagement score and engagement metrics for a specific account, including channel-level breakdown and trend data."
        },
        {
          "info": {
            "name": "Demandbase Get engagement summary",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/engagement/engagement/summary",
            "params": [
              {
                "name": "start_date",
                "value": "",
                "type": "query"
              },
              {
                "name": "end_date",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Number of top accounts to return"
              }
            ]
          },
          "docs": "Retrieve a summary of engagement metrics across all tracked accounts, including top engaged accounts and trend data."
        }
      ]
    },
    {
      "info": {
        "name": "Activities",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase Get account activities",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/engagement/accounts/:accountId/activities",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path",
                "description": "Demandbase account unique identifier"
              },
              {
                "name": "type",
                "value": "",
                "type": "query",
                "description": "Filter by activity type"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve the activity stream for a specific account, including web visits, email interactions, ad engagements, and other tracked events."
        }
      ]
    },
    {
      "info": {
        "name": "Intent",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase Get account intent signals",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/engagement/accounts/:accountId/intent",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path",
                "description": "Demandbase account unique identifier"
              }
            ]
          },
          "docs": "Retrieve intent signals and buying indicators for a specific account, including keyword-level intent data and trend information."
        }
      ]
    },
    {
      "info": {
        "name": "Webhooks",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List webhooks",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/engagement/webhooks"
          },
          "docs": "Retrieve all configured webhook subscriptions."
        },
        {
          "info": {
            "name": "Demandbase Create a webhook",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/engagement/webhooks",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new webhook subscription to receive real-time notifications for engagement events."
        },
        {
          "info": {
            "name": "Demandbase Delete a webhook",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/engagement/webhooks/:webhookId",
            "params": [
              {
                "name": "webhookId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete a webhook subscription."
        }
      ]
    }
  ],
  "bundled": true
}