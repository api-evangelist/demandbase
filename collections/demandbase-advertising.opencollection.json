{
  "opencollection": "1.0.0",
  "info": {
    "name": "Demandbase Advertising API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Campaigns",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List campaigns",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/advertising/campaigns",
            "params": [
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by campaign status"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Pagination offset"
              }
            ]
          },
          "docs": "Retrieve a list of advertising campaigns with optional filtering by status, date range, and other parameters."
        },
        {
          "info": {
            "name": "Demandbase Create a campaign",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/advertising/campaigns",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new advertising campaign with targeting and budget settings."
        },
        {
          "info": {
            "name": "Demandbase Get a campaign",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/advertising/campaigns/:campaignId",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path",
                "description": "Campaign unique identifier"
              }
            ]
          },
          "docs": "Retrieve details of a specific advertising campaign."
        },
        {
          "info": {
            "name": "Demandbase Update a campaign",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.demandbase.com/advertising/campaigns/:campaignId",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path",
                "description": "Campaign unique identifier"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update an existing advertising campaign."
        },
        {
          "info": {
            "name": "Demandbase Delete a campaign",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/advertising/campaigns/:campaignId",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path",
                "description": "Campaign unique identifier"
              }
            ]
          },
          "docs": "Delete an advertising campaign."
        }
      ]
    },
    {
      "info": {
        "name": "Analytics",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase Get campaign analytics",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/advertising/campaigns/:campaignId/analytics",
            "params": [
              {
                "name": "campaignId",
                "value": "",
                "type": "path",
                "description": "Campaign unique identifier"
              },
              {
                "name": "start_date",
                "value": "",
                "type": "query",
                "description": "Start date for analytics (YYYY-MM-DD)"
              },
              {
                "name": "end_date",
                "value": "",
                "type": "query",
                "description": "End date for analytics (YYYY-MM-DD)"
              }
            ]
          },
          "docs": "Retrieve performance analytics for a specific campaign including impressions, clicks, spend, and account-level engagement metrics."
        }
      ]
    },
    {
      "info": {
        "name": "Audiences",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Demandbase List audiences",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/advertising/audiences",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve a list of audience segments for advertising targeting."
        },
        {
          "info": {
            "name": "Demandbase Create an audience",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.demandbase.com/advertising/audiences",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new audience segment for advertising targeting."
        },
        {
          "info": {
            "name": "Demandbase Get an audience",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.demandbase.com/advertising/audiences/:audienceId",
            "params": [
              {
                "name": "audienceId",
                "value": "",
                "type": "path",
                "description": "Audience unique identifier"
              }
            ]
          },
          "docs": "Retrieve details of a specific audience segment."
        },
        {
          "info": {
            "name": "Demandbase Delete an audience",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.demandbase.com/advertising/audiences/:audienceId",
            "params": [
              {
                "name": "audienceId",
                "value": "",
                "type": "path",
                "description": "Audience unique identifier"
              }
            ]
          },
          "docs": "Delete an audience segment."
        }
      ]
    }
  ],
  "bundled": true
}